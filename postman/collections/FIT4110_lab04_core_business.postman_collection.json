              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Unknown card is denied\", function () {",
                  "    pm.expect(pm.response.code).to.equal(200);",
                  "});",
                  "",
                  "pm.test(\"Unknown card returns UNKNOWN_CARD reason\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.allow).to.equal(false);",
                  "    pm.expect(json.reasonCode).to.equal('UNKNOWN_CARD');",
