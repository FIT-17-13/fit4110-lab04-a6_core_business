  "item": [
    {
      "name": "01_Functional",
      "item": [
        {
          "name": "GET /health - Health check",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has status ok\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.status).to.equal('ok');",
                  "});",
                  "",
                  "pm.test(\"Response has service name and version\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.service).to.equal('core-business');",
                  "    pm.expect(json.version).to.equal('1.0.0');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/health",
              "host": ["{{baseUrl}}"],
              "path": ["health"]
            }
          }
        },
        {
          "name": "POST /access/check - Valid card allowed",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has decision properties\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('decisionId');",
                  "    pm.expect(json).to.have.property('allow');",
                  "    pm.expect(json).to.have.property('reasonCode');",
                  "});",
                  "",
                  "pm.test(\"Valid card is allowed\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json.allow).to.equal(true);",
                  "    pm.expect(json.reasonCode).to.equal('VALID_CARD');",
                  "});",
                  "",
                  "// Save decision ID for later use",
                  "const json = pm.response.json();",
                  "pm.environment.set('lastDecisionId', json.decisionId);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\"cardId\":\"RFID-2026-001\",\"gateId\":\"gate-main-01\",\"direction\":\"IN\",\"idempotencyKey\":\"idem-001\"}"
            },
            "url": {
              "raw": "{{baseUrl}}/access/check",
              "host": ["{{baseUrl}}"],
              "path": ["access", "check"]
            }
          }
        },
        {
          "name": "GET /policies/access - List policies",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has data array\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('data');",
                  "    pm.expect(json.data).to.be.an('array');",
                  "});",
                  "",
                  "pm.test(\"Each policy has policyId and policyType\", function () {",
                  "    const json = pm.response.json();",
                  "    json.data.forEach(policy => {",
                  "        pm.expect(policy).to.have.property('policyId');",
                  "        pm.expect(policy).to.have.property('policyType');",
                  "    });",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/policies/access?limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["policies", "access"],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                }
              ]
            }
          }
        },
        {
          "name": "GET /decisions - List decisions",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has data array\", function () {",
                  "    const json = pm.response.json();",
                  "    pm.expect(json).to.have.property('data');",
                  "    pm.expect(json.data).to.be.an('array');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/decisions?limit=20",
